{
  "name": "lrc-file-parser",
  "version": "2.4.2",
  "description": "Javascript-based lrc file parser",
  "main": "./dist/lrc-file-parser.js",
  "module": "./dist/lrc-file-parser.esm.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rollup -c && rollup -c rollup.config.iife.js"
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/lrc-file-parser.js",
      "default": "./dist/lrc-file-parser.esm.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lyswhut/lrc-file-parser.git"
  },
  "keywords": [
    "javascript",
    "lrc",
    "web"
  ],
  "author": "lyswhut",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lyswhut/lrc-file-parser/issues"
  },
  "homepage": "https://github.com/lyswhut/lrc-file-parser#readme",
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.20.7",
    "@babel/preset-env": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/recommended": "^1.0.13",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "rollup": "^4.62.2",
    "typescript": "^6.0.3"
  }
}

